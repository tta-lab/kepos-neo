{
  "name": "kepos-neo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "imports": {
    "node:fs/promises": {
      "bare": "bare-fs/promises",
      "default": "node:fs/promises"
    },
    "node:http": {
      "bare": "bare-http1",
      "default": "node:http"
    },
    "node:net": {
      "bare": "bare-net",
      "default": "node:net"
    },
    "node:path": {
      "bare": "bare-path",
      "default": "node:path"
    },
    "node:stream": {
      "bare": "bare-stream",
      "default": "node:stream"
    }
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22 <23",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=10 <11",
      "onFail": "error"
    }
  },
  "scripts": {
    "android:fetch-bare-kit": "tsx scripts/fetch-bare-kit.ts",
    "android:bundle": "npm run build:packages && tsc -p tsconfig.bare.json && tsx scripts/build-android-worklet.ts",
    "android:assemble": "npm run android:fetch-bare-kit && npm run android:bundle && ./android/gradlew -p android assembleDebug",
    "android:install": "npm run android:assemble && adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:check": "npm run android:fetch-bare-kit && npm run android:bundle && ./android/gradlew -p android testDebugUnitTest lintDebug assembleDebug",
    "android:device-check": "npm run android:fetch-bare-kit && npm run android:bundle && ./android/gradlew -p android connectedDeviceTestAndroidTest",
    "build:packages": "tsc -b --clean packages/bare-host-protocol packages/kepos-android-worklet && tsc -b packages/bare-host-protocol packages/kepos-android-worklet",
    "check": "npm run build:packages && npm run typecheck && npm run test:coverage && npm run check:home",
    "check:home": "npm run build:home && git diff --exit-code -- home/styles.css",
    "typecheck": "tsc --noEmit",
    "test": "npm run build:packages && node --import tsx --test",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include=\"src/**/*.ts\" --test-coverage-include=\"packages/*/src/**/*.ts\" --test-coverage-lines=90 --test-coverage-branches=80 --test-coverage-functions=90 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.info",
    "build:home": "tailwindcss -i home/styles.input.css -o home/styles.css --minify",
    "kepos": "tsx src/cli/main.ts"
  },
  "dependencies": {
    "b4a": "^1.8.1",
    "bare-fs": "^4.7.4",
    "bare-http1": "^4.5.7",
    "bare-net": "^2.3.2",
    "bare-path": "^3.1.1",
    "bare-stream": "^2.13.3",
    "compact-encoding": "^3.3.0",
    "hypercore-crypto": "^3.7.0",
    "hyperdht": "^6.33.0",
    "protomux": "^3.11.0",
    "smol-toml": "^1.7.0",
    "sodium-universal": "^5.0.1",
    "streamx": "^2.28.0",
    "tsx": "^4.23.1",
    "which-runtime": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/b4a": "^1.6.5",
    "@types/node": "^26.1.1",
    "bare-link": "^3.3.0",
    "bare-pack": "^2.2.1",
    "daisyui": "^5.6.16",
    "extract-zip": "^2.0.1",
    "https-proxy-agent": "^9.1.0",
    "lefthook": "^2.1.10",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2"
  }
}
