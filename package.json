{
  "name": "kepos-neo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22 <23",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=10 <11",
      "onFail": "error"
    }
  },
  "scripts": {
    "check": "npm run typecheck && npm test && npm run check:home",
    "check:home": "npm run build:home && git diff --exit-code -- home/styles.css",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test",
    "build:home": "tailwindcss -i home/styles.input.css -o home/styles.css --minify",
    "kepos": "tsx src/cli/main.ts"
  },
  "dependencies": {
    "compact-encoding": "^3.3.0",
    "hyperdht": "^6.33.0",
    "protomux": "^3.11.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@types/node": "^26.1.1",
    "daisyui": "^5.6.16",
    "lefthook": "^2.1.10",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
